 (deps %{bin:spice} test_sessions_panel.exe)
 (action
  (progn
   (setenv
    SPICE_BIN
    %{bin:spice}
    (run ./test_sessions_panel.exe))
   (diff? test_sessions_panel.ml test_sessions_panel.ml.corrected))))

; The sessions browse screen runs no turns (resume replay is pure; rename and
; delete are host store writes) — no fake provider, just the real binary.

(rule
 (alias runtest)
 (deps %{bin:spice} test_sessions_screen.exe)
 (action
  (progn
   (setenv
    SPICE_BIN
    %{bin:spice}
    (run ./test_sessions_screen.exe))
   (diff? test_sessions_screen.ml test_sessions_screen.ml.corrected))))

; Launch resume ([spice resume <id>]) seeds session documents and replays them
; without a turn, but the resume-then-submit test drives a real turn, so the
; suite needs the fake provider server alongside the real binary.

(rule
 (alias runtest)
 (deps
  %{bin:spice}
  ../blackbox/bin/spice_fake_provider_server.exe
  test_resume.exe)
 (action
  (progn
   (setenv
    SPICE_BIN
    %{bin:spice}
    (setenv
     SPICE_FAKE_PROVIDER_BIN
     %{dep:../blackbox/bin/spice_fake_provider_server.exe}
     (run ./test_resume.exe)))
   (diff? test_resume.ml test_resume.ml.corrected))))

; The settings screen runs no turns: the config/status/skills tabs read host
; views and write config files, none of which needs the provider.

(rule
