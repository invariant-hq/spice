    SPICE_BIN
    %{bin:spice}
    (run ./test_settings.exe))
   (diff? test_settings.ml test_settings.ml.corrected))))

; The transcript tests run a real turn, so they add the fake provider server as
; a dependency and pass its path through SPICE_FAKE_PROVIDER_BIN.

(rule
 (alias runtest)
 (deps
  %{bin:spice}
  ../blackbox/bin/spice_fake_provider_server.exe
  test_transcript.exe)
 (action
  (progn
   (setenv
    SPICE_BIN
    %{bin:spice}
    (setenv
     SPICE_FAKE_PROVIDER_BIN
     %{dep:../blackbox/bin/spice_fake_provider_server.exe}
     (run ./test_transcript.exe)))
   (diff? test_transcript.ml test_transcript.ml.corrected))))

