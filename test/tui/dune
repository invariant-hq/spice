; The login / logout pickers, masked api-key entry, esc ladder, and browser
; panel are deterministic with an env credential and no network (09-auth cases
; 1-3, 6, 7). The device-code case (5) drives the fake provider server as a
; local auth issuer (SPICE_OPENAI_AUTH_BASE_URL), so the exe depends on it.

(rule
 (alias runtest)
 (deps
  %{bin:spice}
  test_auth.exe
  ../blackbox/bin/spice_fake_provider_server.exe)
 (action
  (progn
   (setenv
    SPICE_BIN
    %{bin:spice}
    (setenv
     SPICE_FAKE_PROVIDER_BIN
     %{dep:../blackbox/bin/spice_fake_provider_server.exe}
     (run ./test_auth.exe)))
   (diff? test_auth.ml test_auth.ml.corrected))))

