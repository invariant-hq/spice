; Each feature is its own executable and runtest rule so dune runs the suite
; in parallel. The home screen runs no turns, so the fake provider is not a
; dependency; the tests drive the real spice binary on a pty.

(executables
 (names
  test_home
  test_home_live
  test_transcript
  test_tools
  test_strip
  test_sessions_panel
  test_sessions_screen
  test_resume
  test_settings
  test_model_panel
  test_commands
  test_composer
  test_mention
  test_history
  test_notices
  test_exit
  test_dialogs
  test_todo_board
  test_threads
  test_auth
  test_review
  test_side_pane)
 (modules
  test_home
  test_home_live
  test_transcript
  test_tools
  test_strip
  test_sessions_panel
  test_sessions_screen
  test_resume
  test_settings
  test_model_panel
  test_commands
  test_composer
  test_mention
  test_history
  test_notices
  test_exit
  test_dialogs
  test_todo_board
  test_threads
  test_auth
  test_review
  test_side_pane)
 (libraries unix windtrap tui_harness)
 (preprocess
  (pps ppx_windtrap)))

(rule
 (alias runtest)
 (deps %{bin:spice} test_home.exe)
 (action
  (progn
   (setenv
    SPICE_BIN
    %{bin:spice}
    (run ./test_home.exe))
   (diff? test_home.ml test_home.ml.corrected))))

(rule
 (alias runtest)
 (deps %{bin:spice} test_home_live.exe)
 (action
  (progn
   (setenv
    SPICE_BIN
    %{bin:spice}
    (run ./test_home_live.exe))
   (diff? test_home_live.ml test_home_live.ml.corrected))))

; The session quick-switch panel runs no turns, so like the home tests it needs
; only the real spice binary — no fake provider.

(rule
