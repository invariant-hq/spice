# This file is generated by dune, edit dune-project instead
opam-version: "2.0"
synopsis: "The OCaml coding agent"
description: """
Spice is a coding agent specialized for OCaml development. It uses OCaml's type system, build tools, package ecosystem, and editor diagnostics as first-class context so agents can make changes that are faster to produce, easier to review, and less likely to break than generic coding-agent output.

Spice is built for safer, more productive agentic development in real OCaml codebases."""
maintainer: ["Thibaut Mattio <thibaut.mattio@gmail.com>"]
authors: ["Thibaut Mattio <thibaut.mattio@gmail.com>"]
license: "ISC"
tags: [
  "ai" "cli" "coding-agent" "developer-tools" "ocaml" "org:invariant-hq"
]
homepage: "https://github.com/invariant-hq/spice"
doc: "https://github.com/invariant-hq/spice#readme"
bug-reports: "https://github.com/invariant-hq/spice/issues"
depends: [
  "dune" {>= "3.22"}
  "ocaml" {>= "5.5.0"}
  "jsont" {>= "0.2.0"}
  "bytesrw" {>= "0.3.0"}
  "cmdliner" {>= "2.0.0"}
  "logs" {>= "0.10.0"}
  "mtime"
  "csexp"
  "dune-build-info"
  "dune-rpc"
  "eio"
  "eio_main"
  "xdg"
  "ca-certs"
  "cohttp"
  "cohttp-eio"
  "cstruct"
  "domain-name"
  "mirage-crypto-rng"
  "tls"
  "tls-eio"
  "uri"
  "yaml"
  "mosaic"
  "matrix"
  "matrix-eio"
  "deepseek"
  "windtrap" {with-test & >= "0.1.0"}
  "ppx_windtrap" {with-test & >= "0.1.0"}
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
dev-repo: "git+https://github.com/invariant-hq/spice.git"
x-maintenance-intent: ["(latest)"]
